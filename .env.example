# ─────────────────────────────────────────────────────
# WicScan Risk Manager — Environment Configuration
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────────────

# Application
ENVIRONMENT=development
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_AT_LEAST_32_CHARS
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Ports
FRONTEND_PORT=3000
BACKEND_PORT=8000
SCANNER_MANAGER_PORT=8001
AI_GATEWAY_PORT=8002
POSTGRES_PORT=5432
REDIS_PORT=6379
SONARQUBE_PORT=9000
OLLAMA_PORT=11434

# PostgreSQL
POSTGRES_PASSWORD=wicscan123

# Redis
REDIS_PASSWORD=

# SonarQube
SONARQUBE_TOKEN=
SONARQUBE_ADMIN_USER=admin
SONARQUBE_ADMIN_PASSWORD=admin

# MobSF (opcional, análisis de apps móviles)
MOBSF_API_KEY=mobsf_secret_key

# AI Providers (fill in the ones you want to use)
